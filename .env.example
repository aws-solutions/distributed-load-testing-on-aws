# CDK Parameters
TARGET_REGION=us-west-2

# Uncomment the stack name matching your deployment mode:
MAIN_STACK_NAME=distributed-load-testing-on-aws                    # Standard CloudFront deployment
# MAIN_STACK_NAME=distributed-load-testing-on-aws-alb-ecs          # ALB + ECS deployment
# MAIN_STACK_NAME=distributed-load-testing-on-aws-headless         # Headless deployment
REGIONAL_STACK_NAME=distributed-load-testing-on-aws-regional

# Stack Parameters
ADMIN_NAME=username_no_spaces
ADMIN_EMAIL=email@example.com

# Regional Stacks (space-separated list of regions for multi-region deployment)
# Used by: make regional-deploy (deploys to all listed regions sequentially)
# Override with: make regional-deploy REGION=us-west-2 (single region)
# Example: REGIONAL_STACKS=us-west-2 eu-west-1 ap-southeast-2
REGIONAL_STACKS=

# ALB+ECS Stack Parameters (required when MAIN_STACK_NAME uses the ALB+ECS stack)
CONSOLE_DOMAIN_NAME=dlt.example.com
ACM_CERTIFICATE_ARN=arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
