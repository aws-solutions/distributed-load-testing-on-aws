      },
      "Properties": {
        "GroupDescription": "ALB security group - HTTPS from internet",
        "SecurityGroupIngress": [
          {
            "CidrIp": "0.0.0.0/0",
            "Description": "Allow HTTPS from internet",
            "FromPort": 443,
            "IpProtocol": "tcp",
            "ToPort": 443,
          },
