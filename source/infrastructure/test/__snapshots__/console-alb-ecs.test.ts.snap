            {
              "id": "W2",
              "reason": "Internet-facing ALB requires ingress from 0.0.0.0/0 for HTTPS traffic",
            },
            {
              "id": "W5",
              "reason": "Egress restricted to ECS tasks only via explicit rule",
            },
            {
              "id": "W9",
              "reason": "Internet-facing ALB requires ingress from 0.0.0.0/0",
