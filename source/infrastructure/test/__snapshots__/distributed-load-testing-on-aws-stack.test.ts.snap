        "Dimensions": [
          {
            "Name": "SolutionId",
            "Value": "testId",
          },
        ],
        "EvaluationPeriods": 1,
        "MetricName": "OrphanCleanupFailures",
        "Namespace": "distributed-load-testing",
        "Period": 300,
        "Statistic": "Sum",
