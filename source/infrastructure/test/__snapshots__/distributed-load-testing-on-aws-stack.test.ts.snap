          },
          "detail-type": [
            "Step Functions Execution Status Change",
          ],
          "source": [
            "aws.states",
          ],
        },
        "State": "ENABLED",
        "Targets": [
          {
            "Arn": {
              "Fn::GetAtt": [
                "DLTLambdaFunctionSFNFailureHandler928EB56D",
